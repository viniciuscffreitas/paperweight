# ─── Paperweight Environment Variables ───
#
# Copy this file: cp .env.example .env
# Then fill in the values you need.

# ─── Required ───

# Claude Code OAuth token (get it by running: claude /login)
# This is the token that lets paperweight spawn Claude Code sessions.
CLAUDE_CODE_OAUTH_TOKEN=

# Path to the paperweight repo itself (for the self-management project)
PAPERWEIGHT_REPO_PATH=/path/to/your/paperweight/clone

# ─── Auth (recommended) ───

# Set any random string to enable login/register with invite codes.
# Without this, the dashboard is open to anyone with the URL.
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ─── Integrations (all optional) ───

# Slack — incoming webhook for run notifications + overnight digest
# Create at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=

# Linear — API key for posting comments + updating issue status
# Create at: Linear → Settings → Account → API → Personal API Key
LINEAR_API_KEY=

# Linear webhook signature verification
# Set when creating the webhook in Linear → Settings → API → Webhooks
LINEAR_WEBHOOK_SECRET=

# GitHub webhook signature verification
# Set when creating the webhook in your repo → Settings → Webhooks
GITHUB_WEBHOOK_SECRET=

# GitHub token — for GitHub API client (issue polling, repo listing)
# The `gh` CLI handles git push/PR creation separately via its own auth.
GITHUB_TOKEN=

# Discord — bot token + guild ID for run notifications
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
