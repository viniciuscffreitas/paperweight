# ─── Required CLI tools (not env vars, but must be in $PATH) ───
# claude   → Install: https://docs.anthropic.com/en/docs/claude-code
#             Then: claude /login
# gh       → Install: https://cli.github.com/
#             Then: gh auth login

# ─── Linear (optional — for webhook triggers + issue updates) ───
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINEAR_WEBHOOK_SECRET=your_linear_webhook_secret

# ─── GitHub (optional — for webhook triggers) ───
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret

# ─── Slack (optional — for run notifications) ───
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ─── Discord (optional — for run notifications) ───
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=your_discord_guild_id
